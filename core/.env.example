# charkathat configuration — copy to ~/.config/charkathat/.env (or a local .env)
# At least ONE provider key is required.

# Google Gemini (recommended — edit + reference images). Free key:
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (great for logos / text-in-image). https://platform.openai.com/api-keys
OPENAI_API_KEY=

# HuggingFace (free, fast FLUX.1-schnell drafts). https://huggingface.co/settings/tokens
HF_TOKEN=

# --- optional tuning ---
# CHARKATHAT_GEMINI_MODEL=gemini-3-pro-image-preview
# CHARKATHAT_OPENAI_MODEL=gpt-image-1
# CHARKATHAT_HF_MODEL=black-forest-labs/FLUX.1-schnell
# CHARKATHAT_OUTPUT_DIR=charkathat-output
# CHARKATHAT_REQUEST_TIMEOUT_MS=90000
# CHARKATHAT_LOG_LEVEL=info
# CHARKATHAT_PREFERRED_PROVIDER=gemini
